# Copper Thesis Dashboard — environment variables
# Copy this file to .env and fill in your keys.

# FRED API key (free) — get one at:
#   https://fred.stlouisfed.org/docs/api/api_key.html
# Used for: 10Y TIPS real yield (DFII10) and USD/CNY (DEXCHUS)
FRED_API_KEY=your_fred_key_here

# Groq API key (free) — same key used by your Jarvis agent
#   https://console.groq.com → API Keys
# Used for: AI analyst brief (Llama-3.3-70b-versatile, free tier)
GROQ_API_KEY=your_groq_key_here

# Refresh password (optional) — set this when deploying publicly on Streamlit Cloud.
# When set, the Refresh button requires this password before running the pipeline.
# Leave blank (or omit entirely) for local development.
REFRESH_PASSWORD=
